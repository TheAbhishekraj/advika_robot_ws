<?xml version="1.0"?>
<!--
  Advika 3.0 URDF Model
  Compatible with Gazebo Harmonic + ROS2 Jazzy
  Includes: differential drive, LiDAR, ToF array, dual cameras, IMU
-->
<robot name="advika">

  <!-- ==================== MATERIALS ==================== -->
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="white">
    <color rgba="0.9 0.9 0.9 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.1 0.3 0.8 1.0"/>
  </material>
  <material name="green">
    <color rgba="0.1 0.7 0.2 1.0"/>
  </material>
  <material name="transparent">
    <color rgba="0.5 0.5 0.5 0.3"/>
  </material>

  <!-- ==================== BASE LINK ==================== -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.24 0.15"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <geometry>
        <box size="0.30 0.24 0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.075" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.0125" ixy="0" ixz="0"
               iyy="0.0165" iyz="0"
               izz="0.0245"/>
    </inertial>
  </link>

  <!-- ==================== LEFT WHEEL ==================== -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.00008"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.115 0.0325" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== RIGHT WHEEL ==================== -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.0325" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.15"/>
      <inertia ixx="0.0001" ixy="0" ixz="0"
               iyy="0.0001" iyz="0"
               izz="0.00008"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.115 0.0325" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- ==================== CASTER WHEEL (FRONT) ==================== -->
  <link name="caster_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.12 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- ==================== CASTER WHEEL (REAR) ==================== -->
  <link name="caster_wheel_rear">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_wheel_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_rear"/>
    <origin xyz="-0.12 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LIDAR TOWER ==================== -->
  <link name="lidar_tower">
    <visual>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.08"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.08"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.0002" ixy="0" ixz="0"
               iyy="0.0002" iyz="0"
               izz="0.0001"/>
    </inertial>
  </link>

  <joint name="lidar_tower_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_tower"/>
    <origin xyz="0 0 0.15" rpy="0 0 0"/>
  </joint>

  <!-- ==================== LIDAR SENSOR ==================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0"
               iyy="0.00001" iyz="0"
               izz="0.00001"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="lidar_tower"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
  </joint>

  <!-- ==================== HORIZON CAMERA ==================== -->
  <link name="horizon_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0"
               izz="0.000003"/>
    </inertial>
  </link>

  <joint name="horizon_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="horizon_camera_link"/>
    <origin xyz="0.14 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ==================== FLOOR CAMERA ==================== -->
  <link name="floor_camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.04 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.000003" ixy="0" ixz="0"
               iyy="0.000003" iyz="0"
               izz="0.000003"/>
    </inertial>
  </link>

  <joint name="floor_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="floor_camera_link"/>
    <origin xyz="0.12 0 0.02" rpy="0 0.785 0"/>
  </joint>

  <!-- ==================== TOF ARRAY ==================== -->
  <link name="tof_array_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.01"/>
      </geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.04 0.04 0.01"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="tof_array_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tof_array_link"/>
    <origin xyz="0.15 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ==================== IMU ==================== -->
  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
      <material name="transparent"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.0000001" ixy="0" ixz="0"
               iyy="0.0000001" iyz="0"
               izz="0.0000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ==================== DISPLAY SCREEN ==================== -->
  <link name="display_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.005"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.04 0.005"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="display_joint" type="fixed">
    <parent link="base_link"/>
    <child link="display_link"/>
    <origin xyz="0 0 0.155" rpy="0 0 0"/>
  </joint>

  <!-- ==================== GAZEBO PLUGINS ==================== -->

  <!-- Differential Drive Plugin -->
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="diff_drive">
      <ros>
        <namespace>/advika</namespace>
      </ros>
      <update_rate>50</update_rate>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.23</wheel_separation>
      <wheel_diameter>0.065</wheel_diameter>
      <max_wheel_torque>0.5</max_wheel_torque>
      <max_wheel_acceleration>2.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_source>1</odometry_source>
      <command_topic>cmd_vel</command_topic>
      <odometry_topic>odom</odometry_topic>
      <robot_base_frame>base_link</robot_base_frame>
      <odometry_frame>odom</odometry_frame>
    </plugin>
  </gazebo>

  <!-- LiDAR Plugin (GPU Ray) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin filename="libgazebo_ros_ray_sensor.so" name="lidar_plugin">
        <ros>
          <namespace>/advika</namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Horizon Camera Plugin -->
  <gazebo reference="horizon_camera_link">
    <sensor name="horizon_camera" type="camera">
      <camera>
        <horizontal_fov>1.309</horizontal_fov>  <!-- 75 degrees -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_camera.so" name="horizon_camera_plugin">
        <ros>
          <namespace>/advika</namespace>
          <remapping>~/image_raw:=horizon_camera/image_raw</remapping>
          <remapping>~/camera_info:=horizon_camera/camera_info</remapping>
        </ros>
        <camera_name>horizon_camera</camera_name>
        <frame_name>horizon_camera_link</frame_name>
        <hack_baseline>0.0</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Floor Camera Plugin -->
  <gazebo reference="floor_camera_link">
    <sensor name="floor_camera" type="camera">
      <camera>
        <horizontal_fov>2.094</horizontal_fov>  <!-- 120 degrees -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <plugin filename="libgazebo_ros_camera.so" name="floor_camera_plugin">
        <ros>
          <namespace>/advika</namespace>
          <remapping>~/image_raw:=floor_camera/image_raw</remapping>
          <remapping>~/camera_info:=floor_camera/camera_info</remapping>
        </ros>
        <camera_name>floor_camera</camera_name>
        <frame_name>floor_camera_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ToF Array Plugin (Simulated as Depth Camera) -->
  <gazebo reference="tof_array_link">
    <sensor name="tof_depth" type="depth">
      <camera>
        <horizontal_fov>1.1</horizontal_fov>  <!-- 63 degrees -->
        <image>
          <width>8</width>
          <height>8</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>4.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <update_rate>15</update_rate>
      <visualize>false</visualize>
      <plugin filename="libgazebo_ros_camera.so" name="tof_plugin">
        <ros>
          <namespace>/advika</namespace>
          <remapping>~/depth/image_raw:=tof/depth</remapping>
          <remapping>~/depth/camera_info:=tof/camera_info</remapping>
        </ros>
        <camera_name>tof_array</camera_name>
        <frame_name>tof_array_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- IMU Plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>false</visualize>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <namespace>/advika</namespace>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- Base Link Physics Properties -->
  <gazebo reference="base_link">
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
    <self_collide>false</self_collide>
    <gravity>true</gravity>
  </gazebo>

  <!-- Wheel Friction -->
  <gazebo reference="left_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <self_collide>false</self_collide>
  </gazebo>

  <gazebo reference="right_wheel">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <self_collide>false</self_collide>
  </gazebo>

</robot>
